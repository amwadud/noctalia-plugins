{
  "id": "alarm-clock",
  "name": "Alarm Clock",
  "version": "1.0.0",
  "minNoctaliaVersion": "3.6.0",
  "author": "you",
  "license": "MIT",
  "repository": "https://github.com/yourusername/alarm-clock",
  "description": "A simple alarm clock plugin for Noctalia. Set multiple alarms with labels, sounds and repeat options.",
  "tags": ["Bar", "Panel", "Productivity"],
  "entryPoints": {
    "main": "Main.qml",
    "barWidget": "BarWidget.qml",
    "panel": "Panel.qml",
    "settings": "Settings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "commandPrefix": "alarm",
    "defaultSettings": {
      "alarms": [],
      "soundEnabled": true,
      "notificationEnabled": true,
      "snoozeMinutes": 5,
      "alarmSound": "default"
    }
  }
}
